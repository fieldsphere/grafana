    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "i18n-extract": "i18next-cli extract --sync-primary"
  },
  "author": "Grafana",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/plugin-configs": "workspace:*",
    "@types/jest": "29.5.12",
    "@types/lodash": "4.17.7",
    "@types/node": "24.9.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "glob": "10.5.0",
    "i18next-cli": "^1.24.22",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.5.4",
    "webpack": "5.95.0",
    "webpack-merge": "5.10.0"
  },
  "engines": {
    "node": ">= 22 <25"
  },
